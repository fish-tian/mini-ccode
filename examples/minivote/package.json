{
  "name": "minivote",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run --watch server/main.ts\" \"vite\"",
    "dev:server": "bun run --watch server/main.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun run server/main.ts",
    "seed": "bun run server/seed.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
